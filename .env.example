# Copy to `.env` and fill in. `.env` is gitignored.
# Project loads these via python-dotenv.

# --- Inference providers ---

# Together AI (primary serverless inference for open-weight models).
# https://api.together.ai/settings/api-keys
TOGETHER_API_KEY=

# OpenAI (closed frontier: GPT-5 / GPT-4.x / o-series).
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (closed frontier: Claude Opus 4.x / Sonnet 4.x).
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google (Gemini 2.5 Pro). Used by the `google-genai` SDK.
# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# --- Data + self-hosted weights ---

# HuggingFace token. Required for gated models (Llama family) and faster dataset
# downloads. Create with at least "read" scope.
# https://huggingface.co/settings/tokens
HF_TOKEN=

# --- Notes ---
# Modal does NOT use an env var. Authenticate once with:
#     modal token new
# This writes credentials to ~/.modal.toml. The `modal` Python SDK reads them
# automatically — nothing to add here.
